# --------------------------------
# Appearence
# --------------------------------

# Theme - I do usually switch themes
# theme = Solarized Dark Patched
# theme = Black Metal (Bathory)
# theme = Black Metal (Burzum)
# theme = Black Metal (Immortal)
theme = Jellybeans

# Title
title = " "

# Background opacity; common values: 1, 0.8
background-opacity = 1

# # Window Configuration
window-decoration = none

# Window-Theme
window-theme = ghostty

# Mouse
mouse-hide-while-typing = true
cursor-style = block_hollow

# Font Style
font-family = CaskaydiaCove NFM
font-family-bold = CaskaydiaCove NFM Bold
font-family-italic = CaskaydiaCove NFM Italic
font-family-bold-italic = CaskaydiaCove NFM Italic Bold
font-size = 13

# font-family = VictorMono NFM SemiBold
# font-family-italic = VictorMono NFM SemiBold Italic
# font-family-bold-italic = VictorMono NFM Bold Italic
# font-family-bold = VictorMono NFM Bold

# --------------------------------
# KEYBINDINGS
# --------------------------------

# Resize Split
keybind = super+ctrl+left=resize_split:left,10
keybind = super+ctrl+right=resize_split:right,10
keybind = super+ctrl+down=resize_split:down,10
keybind = super+ctrl+up=resize_split:up,10

# Go-To Split
keybind = super+ctrl+shift+left=goto_split:left
keybind = super+ctrl+shift+right=goto_split:right
keybind = super+ctrl+shift+down=goto_split:down
keybind = super+ctrl+shift+up=goto_split:up

# Scroll
keybind = ctrl+shift+up=scroll_page_lines:-10
keybind = ctrl+shift+down=scroll_page_lines:10

# Fullscreen
keybind = f11=toggle_fullscreen

# Increase and Decrease Font Size
keybind = super+minus=decrease_font_size:1
keybind = super+shift+equal=increase_font_size:1
